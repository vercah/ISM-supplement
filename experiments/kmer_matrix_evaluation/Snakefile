import os
import glob
import numpy as np
# Parameters
k_values = [31] #15, 18, 23, 31
g_values = ["sub50spnegono", "sub50ngono", "sub50spneumo"] 
dataset_sizes = {
    g: sum(1 for _ in open(f"01_datasets/{g}.txt"))
    for g in g_values
}

base_N = np.unique(np.round(np.logspace(np.log10(2), np.log10(10000), num=20))).astype(int).tolist()
all_sizes = [dataset_sizes[g] for g in g_values]
global_N = sorted(set(base_N + all_sizes))

#N_values = {g: sorted(set(n for n in global_N if n <= dataset_sizes[g])) for g in g_values}
#N_values = {g: [dataset_sizes[g]] for g in g_values}
N_values = {g: {50} for g in g_values}
#print("global N up to 2000:", [n for n in global_N if n <=2000])
b=5

rule all:
    input:
        [f"09_runs/{g}_{order}_k{k}_N{n}.runs" for g in g_values for k in k_values for n in N_values[g] for order in ["upgma", "tsp", "randomized", "nj", "worst"]]
#        [f"09_runs/ngono_raxml_k{k}_N50.runs" for k in k_values],
#        [f"09_runs/spneumo_raxml_k{k}_N50.runs" for k in k_values]

rule randomization:
    output:
        txt="02_order_randomization/{dataset}.txt"
    input:
        txt="01_datasets/{dataset}.txt"
    shell:"""
        cat {input.txt} | sort -R > {output.txt}
    """


rule create_selection:
    input:
        txt="02_order_randomization/{dataset}.txt",
    output:
        txt="03_selection/{dataset}.N{N}.txt",
    params:
        seed=313,
    shell:"""
        cat {input.txt} | head -n {wildcards.N} | sort > {output.txt}
    """

rule generate_pres_abs_matrix:
    resources:
        concurrency=1
    output:
	    txt="04_pres_abs/{dataset}_pres_abs_k{k}.tsv",
    input:
        txt="01_datasets/{dataset}.txt",
    shell:"""
        ulimit -n 4096
        kounta --kmer {wildcards.k} --ram 30 --threads 8 --out {output.txt} $(cat {input.txt}) 
        """

rule process_pres_abs_matrix:
    resources:
        concurrency=1
    output:
        matrix="04_pres_abs/{dataset}_proc_pres_abs_k{k}.tsv.xz",
        ids="04_pres_abs/{dataset}_ids_k{k}.tsv.xz",
    input:
        txt="04_pres_abs/{dataset}_pres_abs_k{k}.tsv",
    shell:"""
        cut -f1 {input.txt} > {output.ids}
        ./_transpose_binarize_pres_abs.py {input.txt} | xz -9 -T1 > {output.matrix}
    """

rule calc_ham_dists:
    resources:
        concurrency=1
    output:
        block="05_ham_dists/{dataset}_dist_i{i}_j{j}_b{b}_k{k}.txt.xz"
    input:
        matrix="04_pres_abs/{dataset}_proc_pres_abs_k{k}.tsv.xz",
    shell:"""
        ./_calculate_ham_dist.py {input.matrix} -n {wildcards.b} -i {wildcards.i} -j {wildcards.j} \\
                | xz -9 -T1 \\
                > {output.block}.tmp
        mv {output.block}.tmp {output.block}
    """

rule export_tsp_instance:
    output:
        tsp="06_tsp/{dataset}_k{k}_N{N}/instance.tsp"
    input:
        selection="03_selection/{dataset}.N{N}.txt",
        dists=expand("05_ham_dists/{dataset}_dist_i{i}_j{j}_b{b}_k{k}.txt.xz",dataset="{dataset}",k="{k}",b=b,i=range(b), j=[jj for ii in range(b) for jj in range(ii+1)]),
    shell:"""
        ./_export_tsp_instance.py {input.dists} {input.selection} > {output.tsp} 
    """

rule export_worst_instance:
    output:
        tsp="06_worst/{dataset}_k{k}_N{N}/instance.tsp"
    input:
        selection="03_selection/{dataset}.N{N}.txt",
        dists=expand("05_ham_dists/{dataset}_dist_i{i}_j{j}_b{b}_k{k}.txt.xz",dataset="{dataset}",k="{k}",b=b,i=range(b), j=[jj for ii in range(b) for jj in range(ii+1)]),
    shell:"""
        ./_export_worst_instance.py {input.dists} {input.selection} > {output.tsp} 
    """

rule run_concorde:
    resources:
        concurrency=1
    output:
        sol="06_tsp/{dataset}_k{k}_N{N}/instance.sol",
        log="06_tsp/{dataset}_k{k}_N{N}/log.txt"
    input:
        tsp="06_tsp/{dataset}_k{k}_N{N}/instance.tsp"
    shell:"""
        cd 06_tsp/{wildcards.dataset}_k{wildcards.k}_N{wildcards.N}/ && ~/concorde/concorde -o instance.sol instance.tsp 2>&1 | tee log.txt
        """

rule run_concorde_worst:
    resources:
        concurrency=1
    output:
        sol="06_worst/{dataset}_k{k}_N{N}/instance.sol",
        log="06_worst/{dataset}_k{k}_N{N}/log.txt"
    input:
        tsp="06_worst/{dataset}_k{k}_N{N}/instance.tsp"
    shell:"""
        cd 06_worst/{wildcards.dataset}_k{wildcards.k}_N{wildcards.N}/ && ~/concorde/concorde -o instance.sol instance.tsp 2>&1 | tee log.txt
        """


rule extract_tsp_order:
    output:
        order="08_orders/{dataset}_tsp_k{k}_N{N}.txt",
    input:
        sol="06_tsp/{dataset}_k{k}_N{N}/instance.sol",
        tsp="06_tsp/{dataset}_k{k}_N{N}/instance.tsp",
    shell:"""
        ./_extract_path_from_tsp_solution.py {input.tsp} {input.sol} > {output.order}
    """

rule extract_worst_order:
    output:
        order="08_orders/{dataset}_worst_k{k}_N{N}.txt",
    input:
        sol="06_worst/{dataset}_k{k}_N{N}/instance.sol",
        tsp="06_worst/{dataset}_k{k}_N{N}/instance.tsp",
    shell:"""
        ./_extract_path_from_tsp_solution.py {input.tsp} {input.sol} > {output.order}
    """


rule randomize_order:
    output:
        rand="08_orders/{dataset}_randomized_k{k}_N{N}.txt",
    input:
        order="08_orders/{dataset}_tsp_k{k}_N{N}.txt",
    shell:"""
        cat {input.order} | sort -R > {output.rand}
    """

rule run_upgma_tree:
    output:
        upgmatree="07_trees/{dataset}_upgmatree_N{N}",
    input:
        selection="03_selection/{dataset}.N{N}.txt"
    shell:"""
        attotree -k 31 -m upgma -V $(cat {input.selection}) > {output.upgmatree}
   """

rule run_upgma_order:
    input:
        upgmatree="07_trees/{dataset}_upgmatree_N{N}",
    output:
        order="08_orders/{dataset}_upgma_k{k}_N{N}.txt",
    shell:"""
        ./_postprocess_tree.py -l {output.order} {input.upgmatree} /dev/null
   """

rule run_nj_tree:
    output:
        njtree="07_trees/{dataset}_njtree_N{N}",
    input:
        selection="03_selection/{dataset}.N{N}.txt"
    shell:"""
        attotree -k 31 -m nj -V $(cat {input.selection}) > {output.njtree}
   """

rule run_nj_order:
    input:
        njtree="07_trees/{dataset}_njtree_N{N}",
    output:
        order="08_orders/{dataset}_nj_k{k}_N{N}.txt",
    shell:"""
        ./_postprocess_tree.py -l {output.order} {input.njtree} /dev/null
   """

rule run_raxml_order:
    input:
        njtree="07_trees/ngono_raxml_N{N}.nw",
    output:
        order="08_orders/ngono_raxml_k{k}_N{N}.txt",
