   """

rule compute_final_runs_rand:
    output:
        run="09_runs/{dataset}_randomized_k{k}_N{N}.runs",
    input:
        order="08_orders/{dataset}_randomized_k{k}_N{N}.txt",
        pres_abs_matr="04_pres_abs/{dataset}_proc_pres_abs_k{k}.tsv.xz"
    shell:"""
       ./_evaluate_order_nb_runs.py {input.pres_abs_matr} {input.order}  --outfiles {output.run}

    """

