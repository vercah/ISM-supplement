rule run_attotree:
    input:
        selection="03_selection/{dataset}.N{N}.txt",
    output:
        nw="09_trees/{dataset}_{method}_N{N}.nw",
        time="09_trees/{dataset}_{method}_N{N}.nw.time",
    wildcard_constraints:
        method=r"(nj|upgma)",
    threads: 8
    params:
        experiment=lambda wc: f"attotree_{wc.dataset}_{wc.method}_N{wc.N}",
    shell:
        """
        ../bin/galitime \\
            -l "{output.time}" \\
            -n "{params.experiment}" \\
            "attotree \\
                -t {threads} \\
                -m {wildcards.method} \\
                -L {input.selection} \\
                -V > {output.nw}"
        """


