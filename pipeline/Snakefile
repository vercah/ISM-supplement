rule run_attotree:
    input:
        selection="03_selection/{dataset}.N{N}.txt",
    output:
        nw="08_trees/{dataset}_{method}_N{N}.nw",
        time="08_trees/{dataset}_{method}_N{N}.nw.time",
    wildcard_constraints:
        N=NON_SINGLETON_N,
        method=r"(nj|upgma)",
    threads: 8
    params:
        attotree_k=attotree_k,
        attotree_s=attotree_s,
        experiment=lambda wc: (
            f"attotree_{wc.dataset}_{wc.method}_N{wc.N}_"
            f"k{attotree_k}_s{attotree_s}"
        ),
    shell:
        """
        ../bin/galitime \\
            -l "{output.time}" \\
            -n "{params.experiment}" \\
            "attotree \\
                -t {threads} \\
                -m {wildcards.method} \\
                -k {params.attotree_k} \\
                -s {params.attotree_s} \\
                -L {input.selection} \\
                -V > {output.nw}"
        """


