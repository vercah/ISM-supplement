import glob
import os

configfile: "config.yaml"

CONCORDE_BIN = os.path.abspath("../bin/concorde")
if not os.path.exists(CONCORDE_BIN):
    raise FileNotFoundError(f"Concorde binary not found at {CONCORDE_BIN}")

KNOWN_MATRIX_TYPES = ("kmer", "unitig", "uniqrow")
KNOWN_OUTPUTS = {
    "best_tsp": "optimal",
    "worst_tsp": "worst",
    "nj_attotree": "nj",
    "upgma_attotree": "upgma",
    "randomized": "randomized",
}


def require_mapping(name, value):
    if not isinstance(value, dict):
        raise ValueError(f"Config key '{name}' must be a mapping.")
    return value


def validate_known_keys(name, value, known_keys):
    unknown_keys = sorted(set(value) - set(known_keys))
    if unknown_keys:
        raise ValueError(
            f"Unknown keys under '{name}': {', '.join(unknown_keys)}"
        )


def resolve_enabled_flags(name, value, defaults):
    provided = require_mapping(name, value)
    validate_known_keys(name, provided, defaults)
    resolved = defaults.copy()
    resolved.update(provided)
    if not any(resolved.values()):
        raise ValueError(f"At least one entry under '{name}' must be enabled.")
    return resolved


def parse_config_int(name, default):
    value = config.get(name, default)
    if isinstance(value, bool) or not isinstance(value, int):
        raise ValueError(
            f"Config key '{name}' must be an integer, not {type(value).__name__}."
        )
    return value


def parse_config_nonneg_int(name, default):
    value = config.get(name, default)
    if isinstance(value, bool) or not isinstance(value, int) or value < 0:
        raise ValueError(
            f"Config key '{name}' must be a non-negative integer, not {value!r}."
        )
    return value


def compute_sample_sizes(total_genomes, sampling_conf):
    if total_genomes < 1:
        raise ValueError(f"Dataset size must be >= 1, got {total_genomes}")

    if sampling_conf == 0:
        return [total_genomes]

    values = {1, total_genomes}
    step = 1.0 / sampling_conf
    exponent = 0

    while True:
        raw = 10 ** (exponent * step)
        n_genomes = int(round(raw))
        n_genomes = max(1, min(total_genomes, n_genomes))
        values.add(n_genomes)
        if n_genomes >= total_genomes:
            break
        exponent += 1

    return sorted(values)


default_matrix_flags = {matrix: True for matrix in KNOWN_MATRIX_TYPES}
default_output_flags = {output: True for output in KNOWN_OUTPUTS}

matrix_flags = resolve_enabled_flags(
    "matrices",
    config.get("matrices", {}),
    default_matrix_flags,
)
output_flags = resolve_enabled_flags(
    "outputs",
    config.get("outputs", {}),
    default_output_flags,
)

kmer_sizes = config.get("kmer_sizes", [31])
random_seed = parse_config_int("random_seed", 1)
sampling_conf = parse_config_nonneg_int("sampling_conf", 0)
matrix_types = [matrix for matrix in KNOWN_MATRIX_TYPES if matrix_flags[matrix]]
disabled_matrix_types = [
    matrix for matrix in KNOWN_MATRIX_TYPES if not matrix_flags[matrix]
]
enabled_methods = [
    internal_name
    for config_name, internal_name in KNOWN_OUTPUTS.items()
    if output_flags[config_name]
]
attotree_k = config.get("attotree_k", 31)
attotree_s = config.get("attotree_s", 10000)

dataset_files = sorted(glob.glob(os.path.join("01_datasets", "*.txt")))
datasets = [os.path.splitext(os.path.basename(path))[0] for path in dataset_files]
if not datasets:
    raise FileNotFoundError(
        "No dataset files found in 01_datasets. Add one or more '*.txt' files first."
    )
total_genomes_by_dataset = {
    dataset: sum(1 for _ in open(f"01_datasets/{dataset}.txt"))
    for dataset in datasets
}

n_genomes_by_dataset = {
    dataset: compute_sample_sizes(total_genomes_by_dataset[dataset], sampling_conf)
    for dataset in datasets
}
run_outputs = [
    f"10_runs/{dataset}_{order}_k{k}_N{n}_{matrix}.runs"
    for dataset in datasets
    for k in kmer_sizes
    for n in n_genomes_by_dataset[dataset]
    for order in enabled_methods
    for matrix in matrix_types
]
FINAL_TSV = "11_final_data.tsv"

NON_SINGLETON_N = r"(?:[2-9]|[1-9][0-9]+)"

wildcard_constraints:
    N=r"\d+",
    type=r"(kmer|unitig|uniqrow)"


rule all:
    input:
        run_outputs,
        FINAL_TSV,


rule randomization:
    input:
        txt="01_datasets/{dataset}.txt",
    output:
        txt="02_order_randomization/{dataset}.txt",
    params:
        seed=random_seed,
    shell:
        """
        ./_shuffle_lines_with_seed.py \\
            --seed {params.seed} \\
            {input.txt} \\
            {output.txt}
    """


rule create_selection:
    input:
        txt=rules.randomization.output,
    output:
        txt="03_selection/{dataset}.N{N}.txt",
    shell:
        """
        head -n {wildcards.N} {input.txt} | sort > {output.txt}
    """


rule generate_fulgor_index:
    input:
        txt="01_datasets/{dataset}.txt",
    output:
        fur="04_indices/{dataset}_k{k}.fur",
        time="04_indices/{dataset}_k{k}.fur.time",
    threads: 8
    params:
        minimizer_size=lambda wc: min(20, int(wc.k) - 2),
        ram_gib=12,
        experiment=lambda wc: f"fulgor_index_{wc.dataset}_k{wc.k}",
    shell:
        """
        ulimit -n 4096
        ../bin/galitime \\
            -l "{output.time}" \\
            -n "{params.experiment}" \\
            "fulgor build \\
                -l {input.txt} \\
                -o 04_indices/{wildcards.dataset}_k{wildcards.k} \\
                -k {wildcards.k} \\
                -m {params.minimizer_size} \\
                -d 04_indices/{wildcards.dataset}_k{wildcards.k}_tmp \\
                -g {params.ram_gib} \\
                -t {threads} \\
                --verbose --check"
        """


rule dump_fulgor_files:
    input:
        fur="04_indices/{dataset}_k{k}.fur",
    output:
        sets="05_dumps/{dataset}_k{k}.color_sets.txt",
        meta="05_dumps/{dataset}_k{k}.metadata.txt",
        unitigs="05_dumps/{dataset}_k{k}.unitigs.fa",
        time="05_dumps/{dataset}_k{k}.dump.time",
    params:
        prefix="04_indices/{dataset}_k{k}",
        experiment=lambda wc: f"fulgor_dump_{wc.dataset}_k{wc.k}",
    shell:
        """
        ../bin/galitime \\
            -l "{output.time}" \\
            -n "{params.experiment}" \\
            "fulgor dump -i {input.fur}"
        mv "{params.prefix}.color_sets.txt" {output.sets}
        mv "{params.prefix}.metadata.txt" {output.meta}
        mv "{params.prefix}.unitigs.fa" {output.unitigs}
    """


rule generate_distances_from_dump:
    input:
        sets="05_dumps/{dataset}_k{k}.color_sets.txt",
        meta="05_dumps/{dataset}_k{k}.metadata.txt",
        unitigs="05_dumps/{dataset}_k{k}.unitigs.fa",
    output:
        dists=expand(
            "06_ham_dists/{{dataset}}_k{{k}}_{type}.dists.txt.xz",
            type=matrix_types,
        ),
        time="06_ham_dists/{dataset}_k{k}.build_dists.time",
    threads: 10
    params:
        enabled_matrix_types=" ".join(matrix_types),
        disabled_matrix_types=" ".join(disabled_matrix_types),
        experiment=lambda wc: f"build_dists_{wc.dataset}_k{wc.k}",
    shell:
        """
        ../bin/galitime \\
            -l "{output.time}" \\
            -n "{params.experiment}" \\
            "./_build_dists 05_dumps {wildcards.dataset} {wildcards.k} 06_ham_dists {threads}"
        for matrix in {params.enabled_matrix_types}; do
            xz -9 "06_ham_dists/{wildcards.dataset}_k{wildcards.k}_${{matrix}}.dists.txt"
        done
        if [ -n "{params.disabled_matrix_types}" ]; then
            for matrix in {params.disabled_matrix_types}; do
                rm -f \\
                    "06_ham_dists/{wildcards.dataset}_k{wildcards.k}_${{matrix}}.dists.txt" \\
                    "06_ham_dists/{wildcards.dataset}_k{wildcards.k}_${{matrix}}.dists.txt.xz"
            done
        fi

        """


