rule export_tsp_instance:
    input:
        selection="03_selection/{dataset}.N{N}.txt",
        dists="06_ham_dists/{dataset}_k{k}_{type}.dists.txt.xz",
    output:
        tsp="07_tsp/{dataset}_{variant}_k{k}_N{N}_{type}/instance.tsp",
        time="07_tsp/{dataset}_{variant}_k{k}_N{N}_{type}.export_tsp.time",
    wildcard_constraints:
        N=NON_SINGLETON_N,
        variant=r"(optimal|worst)",
    params:
        experiment=lambda wc: f"tsp_export_{wc.variant}_{wc.dataset}_k{wc.k}_N{wc.N}_{wc.type}",
        output_flag=lambda wc: "-o" if wc.variant == "optimal" else "-w",
    shell:
        """
        ../bin/galitime \\
            -l "{output.time}" \\
            -n "{params.experiment}" \\
            "./_export_tsp_instance.py {input.dists} {input.selection} {params.output_flag} {output.tsp}"
    """


rule run_concorde:
    input:
        tsp="07_tsp/{dataset}_{variant}_k{k}_N{N}_{type}/instance.tsp",
    output:
        sol="07_tsp/{dataset}_{variant}_k{k}_N{N}_{type}/instance.sol",
        log="07_tsp/{dataset}_{variant}_k{k}_N{N}_{type}/log.txt",
        time="07_tsp/{dataset}_{variant}_k{k}_N{N}_{type}.instance.sol.time",
    wildcard_constraints:
        N=NON_SINGLETON_N,
    params:
        concorde=CONCORDE_BIN,
        experiment=lambda wc: f"concorde_{wc.variant}_N{wc.N}_{wc.type}",
    shell:
        """
        repo_pwd="$PWD"

        (
            cd "$(dirname {input.tsp})"
            "$repo_pwd/../bin/galitime" \\
                -l "$repo_pwd/{output.time}" \\
                -n "{params.experiment}" \\
                "'{params.concorde}' \\
                    -o instance.sol \\
                    instance.tsp 2>&1 | tee log.txt"
        )
        """


