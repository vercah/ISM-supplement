    """


rule extract_tsp_order:
    input:
        sol="08_tsp/{dataset}_{variant}_k{k}_N{N}_{type}/instance.sol",
        tsp="08_tsp/{dataset}_{variant}_k{k}_N{N}_{type}/instance.tsp",
    output:
        order="10_orders/{dataset}_{variant}_k{k}_N{N}_{type}.txt",
        time="10_orders/{dataset}_{variant}_k{k}_N{N}_{type}.txt.time",
    wildcard_constraints:
        variant=r"(optimal|worst)",
    params:
        experiment=lambda wc: f"tsp_order_{wc.dataset}_{wc.variant}_k{wc.k}_N{wc.N}_{wc.type}",
    shell:
        """
        ../bin/galitime \\
            -l "{output.time}" \\
            -n "{params.experiment}" \\
            "./_extract_path_from_tsp_solution.py \\
                {input.tsp} \\
                {input.sol} \\
                > {output.order}"
    """


# --------------------------------------
# -----------------FINAL STATS---------------------
# --------------------------------------
rule compute_final_runs:
    input:
        dists="07_ham_dists/{dataset}_k{k}_{type}.dists.txt.xz",
        order="10_orders/{dataset}_{method}_k{k}_N{N}_{type}.txt",
    output:
        run="11_runs/{dataset}_{method}_k{k}_N{N}_{type}.runs",
        time="11_runs/{dataset}_{method}_k{k}_N{N}_{type}.runs.time",
    params:
        experiment=lambda wc: f"final_runs_{wc.dataset}_{wc.method}_k{wc.k}_N{wc.N}_{wc.type}",
    shell:
        """
        # validation
        n_lines=$(wc -l < {input.order})
        n_unique=$(sort {input.order} | uniq | wc -l)
        if [ "$n_lines" -ne "$n_unique" ]; then
            echo "ERROR: duplicate genomes in {input.order}" >&2; exit 1
        fi
        if [ "$n_lines" -ne {wildcards.N} ]; then
            echo "ERROR: {input.order} has $n_lines lines, expected {wildcards.N}" >&2; exit 1
        fi

         ../bin/galitime \\
            -l "{output.time}" \\
            -n "{params.experiment}" \\
            "./_evaluate_order_nb_runs.py \\
                {input.dists} \\
                {input.order} \\
                --num-rows \$( \\
                    if [ '{wildcards.type}' = 'unitig' ]; then \\
                        grep '^num_unitigs=' 05_dumps/{wildcards.dataset}_k{wildcards.k}.metadata.txt | cut -d= -f2; \\
                    elif [ '{wildcards.type}' = 'kmer' ]; then \\
                        grep '^num_kmers=' 05_dumps/{wildcards.dataset}_k{wildcards.k}.metadata.txt | cut -d= -f2; \\
                    elif [ '{wildcards.type}' = 'uniqrow' ]; then \\
                        grep '^num_color_sets=' 05_dumps/{wildcards.dataset}_k{wildcards.k}.metadata.txt | cut -d= -f2; \\
                    fi \\
                ) \\
                --out {output.run}"
    """
